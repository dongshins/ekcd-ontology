<https://dh.aks.ac.kr/> rdf:type owl:NamedIndividual .


#################################################################
# EKCD interpretive confidence level individuals
#################################################################

### http://dh.aks.ac.kr/ontologies/ekcd#Direct
ekcd:Direct
    rdf:type owl:NamedIndividual ,
             ekcd:InterpretiveConfidenceLevel ,
             skos:Concept ;
    rdfs:label "Direct correspondence"@en ;
    rdfs:label "직접 대응"@ko ;
    skos:prefLabel "Direct"@en ;
    skos:prefLabel "직접 대응"@ko ;
    skos:definition "A confidence level assigned to a correspondence explicitly supported by a title, label, textual statement, or other direct evidence in the source material."@en ;
    skos:definition "자료의 표제, 명문, 문자면, 기사 등 직접 근거에 의해 확인되는 대응 관계에 부여하는 신뢰도 수준입니다."@ko .

### http://dh.aks.ac.kr/ontologies/ekcd#Probable
ekcd:Probable
    rdf:type owl:NamedIndividual ,
             ekcd:InterpretiveConfidenceLevel ,
             skos:Concept ;
    rdfs:label "Probable correspondence"@en ;
    rdfs:label "유력한 대응"@ko ;
    skos:prefLabel "Probable"@en ;
    skos:prefLabel "유력한 대응"@ko ;
    skos:definition "A confidence level assigned to a correspondence strongly inferred from multiple pieces of evidence, even when the source materials do not explicitly equate the related units."@en ;
    skos:definition "자료가 두 단위를 직접 동일시하지는 않지만, 복수의 근거와 맥락상 강하게 추론되는 대응 관계에 부여하는 신뢰도 수준입니다."@ko .

### http://dh.aks.ac.kr/ontologies/ekcd#Contextual
ekcd:Contextual
    rdf:type owl:NamedIndividual ,
             ekcd:InterpretiveConfidenceLevel ,
             skos:Concept ;
    rdfs:label "Contextual association"@en ;
    rdfs:label "맥락적 연관"@ko ;
    skos:prefLabel "Contextual"@en ;
    skos:prefLabel "맥락적 연관"@ko ;
    skos:definition "A confidence level assigned to a weaker interpretive association based on broader historical, textual, visual, or political context rather than direct correspondence."@en ;
    skos:definition "직접 대응이나 유력한 대응은 아니지만, 역사적·문헌적·시각적·정치적 맥락 안에서 관련성이 인정되는 관계에 부여하는 신뢰도 수준입니다."@ko .



